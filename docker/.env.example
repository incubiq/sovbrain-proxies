# sovBrain BYO AI Proxy — environment variables
#
# Copy to .env and fill in. NEVER commit .env to source control.

# ---- Required (always) ----

# Base64 Ed25519 public key, copied from sovBrain Settings → External AI → Step 1
SOVBRAIN_PUBLIC_KEY=

# Your sovBrain user ID (UUID), shown alongside the public key
SOVBRAIN_USER_ID=

# ---- Multi-upstream mode (preferred — set whichever upstreams you want) ----

# Anthropic API key (sk-ant-...). Container translates OpenAI ↔ Anthropic Messages API automatically.
ANTHROPIC_API_KEY=

# OpenAI API key (sk-...).
OPENAI_API_KEY=

# Ollama base URL (no trailing slash). Examples:
#   http://host.docker.internal:11434   (local Ollama from Docker Desktop)
#   http://ollama:11434                  (Ollama on the same compose network)
#   https://ai.example.com               (hosted Ollama gateway)
OLLAMA_URL=

# Optional: Bearer token for hosted/gatewayed Ollama (Ollama Cloud, Tailscale
# Funnel with auth, custom reverse proxy with token gating). Omit for true
# local/private Ollama with no auth.
OLLAMA_API_KEY=

# Optional: "anthropic" | "openai" | "ollama". Used when sovBrain sends a model
# name with no prefix. If unset and multiple upstreams are configured,
# unprefixed models return 400 ambiguous_model.
DEFAULT_UPSTREAM=

# ---- Legacy single-upstream mode (back-compat — only used if NO multi-upstream var is set above) ----

# Upstream provider base URL (no trailing slash).
# PROVIDER_UPSTREAM_URL=

# Provider API key. This credential never leaves the container.
# PROVIDER_API_KEY=

# ---- Misc ----

# Listen port (default 8787). Change if it conflicts with another service.
PORT=8787
