# sovBrain BYO AI Proxy — environment variables
#
# Copy to .env and fill in. NEVER commit .env to source control.

# Base64 Ed25519 public key, copied from sovBrain Settings -> External AI -> Step 1
SOVBRAIN_PUBLIC_KEY=

# Your sovBrain user ID (UUID), shown alongside the public key
SOVBRAIN_USER_ID=

# Upstream AI provider base URL (no trailing slash). Examples:
#   https://api.openai.com
#   https://api.anthropic.com
#   https://api.together.xyz
#   http://host.docker.internal:11434  (local Ollama)
PROVIDER_UPSTREAM_URL=

# Provider API key. This credential never leaves the container.
PROVIDER_API_KEY=

# Listen port (default 8787). Change if it conflicts with another service.
PORT=8787
